# Example .env for Pinksteren project
# Copy this file to `.env` in the project root and fill in the values.
# Restart the dev server after changing .env

# Optional: Formspree endpoint (preferred for no-account basic usage)
# Example: VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/yourFormId
VITE_FORMSPREE_ENDPOINT=

# Optional: EmailJS credentials (fallback if you prefer EmailJS)
# Create a service and template in EmailJS and get the public key (user_id)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# SECURITY: Do NOT commit real secrets to public repositories. Keep your .env out of version control.
# You can add `.env` to .gitignore to avoid accidentally committing it.
